<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Web design, local SEO & AI automation",
  "serviceType": "Digital marketing and web development for small businesses",
  "provider": {
    "@type": "Organization",
    "name": "NorthHead Digital",
    "email": "hello@northheaddigital.com"
  },
  "areaServed": "Long Beach Peninsula & Pacific Northwest coast",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Pricing plans",
    "itemListElement": [
      {%- for t in pricing.tiers %}
      {
        "@type": "Offer",
        "name": {{ t.name | dump | safe }},
        "description": {{ t.subtitle | dump | safe }},
        "priceCurrency": "USD",
        "priceSpecification": { "@type": "PriceSpecification", "priceCurrency": "USD", "minPrice": "{{ t.min }}"{% if t.max %}, "maxPrice": "{{ t.max }}"{% endif %} }
      }{% if not loop.last %},{% endif %}
      {%- endfor %}
    ]
  }
}
</script>
