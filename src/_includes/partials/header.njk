<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/" aria-label="{{ site.name }} home">
      <svg class="mark" viewBox="0 0 64 64" aria-hidden="true">
        <circle cx="32" cy="32" r="20" fill="none" stroke="#3e8fb8" stroke-width="3" opacity="0.6"/>
        <path d="M32 12 L40 38 L32 33 L24 38 Z" fill="#14323f"/>
        <path d="M32 52 L26 36 L32 39 L38 36 Z" fill="#2f6b57"/>
      </svg>
      <span>NorthHead<b>Digital</b></span>
    </a>
    <button class="nav-toggle" type="button" aria-label="Toggle menu" aria-controls="nav-links" aria-expanded="false">
      <span></span>
    </button>
    <ul class="nav-links" id="nav-links">
      {% for item in site.navigation %}
        <li><a href="{{ item.url }}" {% if active == item.key %}class="active"{% endif %}>{{ item.label }}</a></li>
      {% endfor %}
      <li><a href="/contact.html" class="btn btn--primary">Free Audit</a></li>
    </ul>
  </div>
</header>
